<?xml version="1.0"?>
<robot name="screw">
    <link name="screw_base_link"/>

    <link name="screw_link">
        <visual name="screw">
            <origin xyz="0.0 0.0 0.0" rpy="-1.5708 0 0"/>
            <geometry>
                <mesh filename="file://@MC_MESH_DIR@/screw.stl"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.6 0.5 1"/>
            </material>
        </visual>
        <inertial>
            <origin xyz="-0.0001681638469675113 -0.0024779164507503317 0.059811455964133025" rpy="0 0 0"/>
            <mass value="0.0698"/>
            <inertia ixx="5.40350E-05" ixy="8.13203E-08" ixz="1.70226E-06"
                    iyy="5.69809E-05" iyz="1.05961E-06" izz="8.81951E-05"/>
        </inertial>
        <collision name="screw_collision">
            <origin xyz="0.0 0.0 0.0" rpy="-1.5708 0 0"/>
            <geometry>
                <mesh scale="0.001 0.001 0.001" filename="file://@MC_MESH_DIR@/screw.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="screw_joint" type="fixed">
        <parent link="screw_base_link"/>
        <child link="screw_link"/>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    </joint>
</robot>
